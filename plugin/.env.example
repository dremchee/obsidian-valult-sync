# Comma, semicolon, or newline separated list of Obsidian plugin directories.
# Example target:
# /absolute/path/to/vault/.obsidian/plugins/obsidian-sync-plugin

# Single vault:
# OBSIDIAN_PLUGIN_DIRS=/absolute/path/to/Vault/.obsidian/plugins/obsidian-sync-plugin

# Multiple vaults:
OBSIDIAN_PLUGIN_DIRS=/absolute/path/to/VaultA/.obsidian/plugins/obsidian-sync-plugin,/absolute/path/to/VaultB/.obsidian/plugins/obsidian-sync-plugin
